# Django
SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgis://bricka:bricka@db:5432/bricka
POSTGRES_DB=bricka
POSTGRES_USER=bricka
POSTGRES_PASSWORD=bricka

# Redis
REDIS_URL=redis://redis:6379/0

# Sentry — dejar vacío en dev desactiva el SDK completamente
SENTRY_DSN=

# Cloudflare R2 — dejar vacíos en dev usa filesystem local
# Cloudflare R2 — usa prefijo AWS porque django-storages/boto3 habla S3 API
R2_ACCESS_KEY_ID=           # R2 API Token
R2_SECRET_ACCESS_KEY=       # R2 API SECRET
R2_STORAGE_BUCKET_NAME=     # nombre del bucket de documentos
R2_ENDPOINT_URL=            # https://<account>.r2.cloudflarestorage.com
R2_CUSTOM_DOMAIN=

R2_PUBLIC_BASE_URL=         # base URL del bucket publico de media
